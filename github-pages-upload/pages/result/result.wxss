.result-page,
.empty-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.report-card,
.dimensions-card,
.reading-card,
.empty-card {
  padding: 34rpx;
}

.report-kicker {
  display: block;
  color: #9d7f3f;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.report-title {
  display: block;
  margin-top: 18rpx;
  color: #20322f;
  font-size: 42rpx;
  line-height: 1.35;
  font-weight: 700;
}

.report-summary {
  display: block;
  margin-top: 20rpx;
  color: #526963;
  font-size: 28rpx;
  line-height: 1.75;
}

.section-title {
  display: block;
  color: #2f5d50;
  font-size: 31rpx;
  font-weight: 700;
}

.dimension {
  margin-top: 28rpx;
}

.dimension-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.dimension-label,
.dimension-value {
  color: #334944;
  font-size: 27rpx;
}

.bar-track {
  margin-top: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(47, 93, 80, 0.11);
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #6f99a8;
}

.reading-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(47, 93, 80, 0.1);
}

.reading-heading {
  display: block;
  color: #20322f;
  font-size: 29rpx;
  font-weight: 700;
}

.reading-body,
.note {
  display: block;
  margin-top: 12rpx;
  color: #526963;
  font-size: 27rpx;
  line-height: 1.72;
}

.note {
  margin-top: 30rpx;
  color: #7a704f;
}
