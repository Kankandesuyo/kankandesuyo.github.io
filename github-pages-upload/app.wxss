page {
  min-height: 100%;
  background: #f7f2e8;
  color: #20322f;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button {
  box-sizing: border-box;
}

button {
  border: 0;
  margin: 0;
  padding: 0;
  line-height: 1.4;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 48rpx 36rpx 64rpx;
}

.soft-panel {
  background: rgba(255, 252, 246, 0.92);
  border: 1rpx solid rgba(44, 74, 68, 0.1);
  border-radius: 8rpx;
  box-shadow: 0 16rpx 42rpx rgba(44, 74, 68, 0.08);
}

.primary-button {
  width: 100%;
  min-height: 92rpx;
  border-radius: 8rpx;
  background: #2f5d50;
  color: #fffdf7;
  font-size: 31rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.secondary-button {
  width: 100%;
  min-height: 86rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(47, 93, 80, 0.34);
  color: #2f5d50;
  font-size: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.muted {
  color: #687b76;
}
